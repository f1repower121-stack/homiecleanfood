# Supabase - Get these from supabase.com > Your Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Omise Payments - Get these from omise.co > Dashboard > Keys
NEXT_PUBLIC_OMISE_PUBLIC_KEY=your_omise_public_key_here
OMISE_SECRET_KEY=your_omise_secret_key_here
