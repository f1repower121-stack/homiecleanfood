{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Claude",
      "type": "claude",
      "request": "launch",
      "program": "${workspaceFolder}/src/index.js",
      "args": ["--port", "3000"],
      "cwd": "${workspaceFolder}",
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}